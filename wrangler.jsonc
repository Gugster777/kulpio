// Kulpio — all-in-one Cloudflare entry point.
//
// One deploy (the connected Workers Build, or `npx wrangler deploy`) serves
// BOTH the app (static assets; non-app files excluded via .assetsignore) and
// the AI/API endpoints (ai-proxy/worker.js: expiry estimates, label reading,
// recipe nutrition, web image search) on a single URL. The app auto-detects
// the same-origin API — no "AI setup" step needed.
//
// The AI endpoints run on Cloudflare Workers AI (free tier) out of the box.
// Optional quality upgrade — add an Anthropic key and they switch to Claude:
//   npx wrangler secret put ANTHROPIC_API_KEY
// (or Cloudflare dashboard → the worker → Settings → Variables and Secrets).
{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "kulpio",
  "main": "ai-proxy/worker.js",
  "compatibility_date": "2026-07-02",
  "ai": {
    "binding": "AI"
  },
  // Community scan log: one row per successful barcode scan from any
  // install (anonymous uid, no personal data). Powers "Popular now".
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "kulpio-scans",
      "database_id": "0bb223ac-f2e1-4490-95d7-8f742e15268d"
    }
  ],
  "observability": {
    "enabled": true
  },
  // Daily expiry pushes: wakes devices whose soonest item expires within
  // ~26h (see worker `scheduled`). Needs VAPID_PUBLIC + VAPID_PRIVATE_JWK
  // secrets (tools/gen-vapid.mjs) and the pushsubs D1 table.
  "triggers": {
    "crons": ["0 7 * * *"]
  },
  "assets": {
    "directory": ".",
    "binding": "ASSETS"
  },
  "compatibility_flags": [
    "nodejs_compat"
  ]
}
